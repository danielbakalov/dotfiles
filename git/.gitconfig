[user]
	name = danny
	email = dbbakalov@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub

# Sign commits with the existing SSH key (no GPG needed). GitHub shows
# "Verified" once the key is added there as a *signing* key.
[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers

[commit]
	gpgsign = true

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

# Remember how conflicts were resolved; auto-reapply on repeat conflicts.
[rerere]
	enabled = true

[diff]
	algorithm = histogram
	colorMoved = default

[merge]
	conflictStyle = zdiff3

# Readable diffs via delta
[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true

[alias]
	st = status -sb
	lg = log --oneline --graph --decorate
	last = log -1 HEAD --stat
	amend = commit --amend --no-edit
	unstage = restore --staged
